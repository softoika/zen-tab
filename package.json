{
  "name": "zen-tab",
  "version": "0.0.0",
  "description": "The tab management tool for Chrome",
  "author": "softoika <zwgntz@gmail.com>",
  "license": "MIT",
  "scripts": {
    "build": "yarn clean && TAILWIND_MODE=build NODE_ENV=production webpack",
    "build:dev": "yarn clean && TAILWIND_MODE=build NODE_ENV=development webpack",
    "build:watch": "yarn clean && TAILWIND_MODE=watch NODE_ENV=development webpack --watch",
    "test": "jest",
    "test:debug": "jest --silent false",
    "lint": "eslint src/ && prettier --check src/",
    "format": "prettier --write src/",
    "clean": "rm -rf dist/"
  },
  "dependencies": {
    "@tailwindcss/forms": "0.5.7",
    "autoprefixer": "10.4.19",
    "dayjs": "1.11.11",
    "postcss": "8.4.39",
    "react": "17.0.2",
    "react-dom": "17.0.2",
    "tailwindcss": "3.4.4"
  },
  "devDependencies": {
    "@testing-library/react-hooks": "7.0.2",
    "@types/chrome": "0.0.268",
    "@types/jest": "27.5.2",
    "@types/react": "17.0.80",
    "@types/react-dom": "17.0.25",
    "@typescript-eslint/eslint-plugin": "5.62.0",
    "@typescript-eslint/parser": "5.62.0",
    "copy-webpack-plugin": "12.0.2",
    "css-loader": "7.1.2",
    "eslint": "8.57.0",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-jsx-a11y": "6.9.0",
    "eslint-plugin-react": "7.34.3",
    "eslint-plugin-react-hooks": "4.6.2",
    "jest": "27.5.1",
    "jest-chrome": "0.8.0",
    "postcss-loader": "8.1.1",
    "prettier": "3.3.3",
    "react-test-renderer": "17.0.2",
    "style-loader": "4.0.0",
    "terser-webpack-plugin": "5.3.10",
    "ts-jest": "27.1.5",
    "ts-loader": "9.5.1",
    "tsconfig-paths-webpack-plugin": "4.1.0",
    "typescript": "4.6.4",
    "webextension-polyfill": "0.8.0",
    "webextension-polyfill-ts": "0.26.0",
    "webpack": "5.93.0",
    "webpack-cli": "5.1.4"
  }
}
